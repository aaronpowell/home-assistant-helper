<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:HomeAssistantHelper.Views"
        x:Class="HomeAssistantHelper.Views.MainChatWindow"
        Title="Home Assistant Helper"
        Width="700" Height="600"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar area -->
        <Grid Grid.Row="0" Background="{DynamicResource SystemControlBackgroundListLowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🏠 Home Assistant Helper" FontWeight="SemiBold"
                       Margin="12,8" FontSize="14" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="⚙ Settings" Click="Settings_Click"
                    Background="Transparent" BorderThickness="0"
                    Padding="12,4" Cursor="Hand" Margin="0,0,8,0"/>
        </Grid>

        <!-- Chat panel -->
        <views:ChatPanel Grid.Row="1" x:Name="ChatContent"/>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#007ACC" Padding="8,3">
            <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11"/>
        </Border>
    </Grid>
</Window>
